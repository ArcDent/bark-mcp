{
  "name": "bark-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:templates": "tsc -p docs/templates/tsconfig.json --noEmit",
    "smoke": "tsx src/smoke.ts",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "sh -c 'vitest run \"$@\" && npm run check:templates' --"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
